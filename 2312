let tries=0;
const WRONG_MSGS=[
  '> INCORRETO. ELE ESTÁ OBSERVANDO VOCÊ FALHAR.',
  '> ERRADO. AS PAREDES OUVEM.',
  '> NÃO. PENSE MAIS FUNDO.',
  '> NEGATIVO. O QUE VOCÊ NÃO VÊ?',
  '> FALSO. O ABISMO ANOTA CADA ERRO.',
  '> TENTATIVA INVÁLIDA. IRENE NÃO ERROU.',
