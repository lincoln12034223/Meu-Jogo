];

function getPhaseIdx(){
  let raw=window.location.hash.replace(/^#+/,'');
  try{raw=decodeURIComponent(raw);}catch(e){}
  const hash=raw.toLowerCase().trim().replace(/-/g,' ');
  if(!hash) return 0;
  for(let i=0;i<PH.length;i++) if(hash===PH[i].answer) return i+1;
  return null;
}

function renderPhase(idx){
  tries=0;
  const cont=document.getElementById('phaseContent');
  cont.innerHTML='';
  spawnDrips(4+Math.floor(Math.random()*6));
  if(idx===null){renderWrong();return;}
  if(idx>=PH.length){renderVictory();return;}
  renderPhaseData(idx);
  const pct=Math.round((idx/PH.length)*100);
  document.getElementById('progress').style.width=pct+'%';
  window.scrollTo(0,0);
}

function renderPhaseData(idx){
  const p=PH[idx];
  const cont=document.getElementById('phaseContent');
  const div=document.createElement('div');
  div.className='phase';
  const block=idx<20?'TUTORIAL':idx<50?'INICIADO':idx<90?'PROFUNDO':idx<130?'ABISMO':'LIMIAR';
  div.innerHTML=`<div class="phase-num">${block} &nbsp;·&nbsp; FASE ${String(idx).padStart(3,'0')} / ${String(PH.length-1).padStart(3,'0')}</div>
    <div class="phase-title${idx>=130?' big':''}">${p.title}</div>`;
  p.build(div);
  div.innerHTML+=`<div class="answer-wrap">
    <input class="answer-input" id="ai" type="text" autocorrect="off" autocapitalize="none" inputmode="text" placeholder="responda aqui" autocomplete="off" spellcheck="false"/>
    <div class="answer-hint" id="ah">&gt; AGUARDANDO</div>
    <div class="tries" id="triesEl"></div>
  </div>`;
  cont.appendChild(div);
  const inp=document.getElementById('ai');
  const hint=document.getElementById('ah');
  inp.focus();
  inp.addEventListener('keydown',e=>{
    if(e.key==='Enter') checkAns(inp.value.trim().toLowerCase(),p.answer,hint,inp);
  });
  inp.addEventListener('input',()=>{hint.textContent='> AGUARDANDO';hint.className='answer-hint';});
}

function checkAns(val,correct,hintEl,inputEl){
  // Normalize: remove accents for comparison
  const norm=s=>s.normalize('NFD').replace(/[\u0300-\u036f]/g,'').toLowerCase().trim();
  if(norm(val)===norm(correct)){
    inputEl.classList.add('ok');
    hintEl.className='answer-hint win';
    hintEl.textContent='> CORRETO. AVANÇANDO...';
    correctSound();
    screenFlash('#003300');
    setTimeout(()=>{window.location.hash='#'+correct.toLowerCase();},900);
  } else {
    tries++;
    inputEl.classList.remove('wrong');
    void inputEl.offsetWidth;
    inputEl.classList.add('wrong');
    hintEl.className='answer-hint err';
    hintEl.textContent=WRONG_MSGS[Math.floor(Math.random()*WRONG_MSGS.length)].replace('${tries}',tries);
    document.getElementById('triesEl').textContent=`tentativas: ${tries}`;
    wrongSound();
    screenFlash('#220000');
    if(tries%3===0) whisper('errado');
    inputEl.value='';
  }
}

