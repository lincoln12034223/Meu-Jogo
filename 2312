function spawnDrips(n=5){
  const w=document.getElementById('drips');
  w.innerHTML='';
  for(let i=0;i<n;i++){
    const d=document.createElement('div');
    d.className='drip';
    d.style.cssText=`left:${Math.random()*100}%;--dur:${2+Math.random()*4}s;--delay:${Math.random()*3}s;--len:${60+Math.random()*120}px;width:${1+Math.random()*2}px;`;
    w.appendChild(d);
  }
}

function screenFlash(color='#3a0000'){
  const f=document.createElement('div');
  f.style.cssText=`position:fixed;top:0;right:0;bottom:0;left:0;background:${color};pointer-events:none;z-index:9995;opacity:.4;transition:opacity .5s;`;
  document.body.appendChild(f);
  setTimeout(()=>{f.style.opacity='0';setTimeout(()=>f.remove(),600);},50);
}

