function mkImg(key,caption='',overlayTxt='',brightness=0.12){
  const wrap=document.createElement('div');
  wrap.className='img-wrap';
  const img=document.createElement('img');
  img.src=IMGS[key]||IMGS.eye;
  img.alt='';
  img.style.filter=`brightness(${brightness}) contrast(1.5) saturate(0.2)`;
  img.loading='lazy';
  wrap.appendChild(img);
  if(overlayTxt){
    const ov=document.createElement('div');
    ov.className='img-overlay';
    ov.innerHTML=`<span>${overlayTxt}</span>`;
    wrap.appendChild(ov);
  }
  const cap=document.createElement('div');
  cap.className='img-caption';
  cap.textContent=caption||'[ aumente o brilho — a verdade está escondida ]';
  wrap.appendChild(cap);
  return wrap;
}

