<div id="adminBtn" onclick="adminOpen()">⚙ ADMIN</div>

<!-- ADMIN OVERLAY -->
<div id="adminOverlay">
  <div class="admin-close" onclick="adminClose()">✕ FECHAR</div>
  <h2>PAINEL ADMIN</h2>
  <div class="admin-sub" id="adminSubtitle">ACESSO RESTRITO — INSIRA A SENHA</div>

  <!-- LOGIN cont -->
  <div id="adminLogin">
    <input type="text" id="adminPwd" style="-webkit-text-security:disc;" placeholder="_ _ _ _ _ _ _ _ _" autocomplete="off" spellcheck="false"/>
    <div class="admin-hint" id="adminHint">&gt; SENHA DO PROJETO</div>
    <div class="admin-enter-btn" onclick="adminAuth()">ENTRAR</div>
  </div>
  <!-- PANEL -->
  <div id="adminPanel">
    <h3>⚙ SELECIONE A FASE</h3>
